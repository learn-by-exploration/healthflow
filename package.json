{
  "name": "healthflow",
  "version": "0.2.0",
  "description": "Self-hosted health & medical tracking service with vitals, medications, appointments, and emergency cards",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "node --test --test-force-exit tests/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --test-force-exit tests/*.test.js",
    "test:security": "node --test --test-force-exit tests/security.test.js tests/auth.test.js",
    "test:crud": "node --test --test-force-exit tests/vitals.test.js tests/medications.test.js tests/appointments.test.js tests/emergency-cards.test.js tests/family-members.test.js",
    "test:smoke": "node --test --test-force-exit tests/e2e-smoke.test.js",
    "audit": "npm audit --audit-level=high || true"
  },
  "keywords": [
    "health-tracker",
    "medical",
    "vitals",
    "medications",
    "self-hosted",
    "sqlite",
    "express"
  ],
  "author": "Learn by Exploration",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0"
  }
}
