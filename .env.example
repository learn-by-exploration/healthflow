# HealthFlow Environment Configuration
# Copy this file to .env and adjust values as needed.
# All values shown are defaults — the app works without a .env file.

# Server
PORT=3461
HOST=0.0.0.0
NODE_ENV=development

# Database directory (where healthflow.db lives)
DB_DIR=./data

# Logging
LOG_LEVEL=info          # silent | error | warn | info | debug

# Session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE_DAYS=7
SESSION_REMEMBER_DAYS=30

# Rate Limiting
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# Auth
BCRYPT_SALT_ROUNDS=12

# Proxy
TRUST_PROXY=0
ALLOWED_ORIGINS=
